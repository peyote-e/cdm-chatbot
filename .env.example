# API Keys
VOYAGE_API_KEY=your_voyage_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ChromaDB (localhost for dev, override to "chromadb" in docker-compose)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=cdm_entities

# Neo4j (localhost for dev, override to "neo4j" in docker-compose)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# OpenAI model
OPENAI_MODEL=gpt-4o

# Local CDM data path (relative to scripts/ingest.py or absolute)
# If set, ingestion reads from local files instead of fetching from GitHub
CDM_LOCAL_PATH=../cdm-data/schemaDocuments

# Cosine similarity threshold above which graph traversal is triggered (0-1)
GRAPH_THRESHOLD=0.75
